<%- include('partials/header') %>

<section class="section-head">
  <div>
    <h2>My Reports</h2>
    <p class="muted">Reports registered under: <%= userRecord.email %></p>
  </div>
</section>

<section class="panel">
  <h3>Recent Badges</h3>
  <div class="badge-row">
    <% if (recentBadges && recentBadges.length) { %>
      <% recentBadges.forEach(b => { %>
        <img src="/badges/<%= b.file %>" alt="<%= b.title %>" style="height:60px; margin-right:8px;" />
      <% }) %>
    <% } else { %>
      <p class="muted">No badges unlocked yet.</p>
    <% } %>
  </div>
</section>

<section class="panel table-panel">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Card Name</th>
          <th>Card Grade</th>
          <th>Card Number</th>
          <th>Card Set Name</th>
          <th>Card Type</th>
          <th>Pokémon Type</th>
          <th>Report Date</th>
          <th>Report Number</th>
        </tr>
      </thead>
      <tbody>
        <% if (!reports.length) { %>
          <tr>
            <td class="empty" colspan="9">No reports found.</td>
          </tr>
        <% } %>

        <% reports.forEach(function(report) { %>
          <tr>
<td>
  <a href="/report/<%= report.id %>">
    <img
      class="thumb"
      src="<%= report.cardImage || 'https://placehold.co/60x80?text=Card' %>"
      alt="<%= report.cardName || 'Card image' %>"
    />
  </a>
</td>
            <td><%= report.cardName || '' %></td>
            <td><%= report.cardGrade || '' %></td>
            <td><%= report.cardNumber || '' %></td>
            <td><%= report.setName || '' %></td>
            <td><%= report.card_category || '' %></td>
            <td><%= report.pokemon_type || '' %></td>
            <td><%= report.reportDate ? new Date(report.reportDate).toLocaleDateString() : '' %></td>
            <td><a href="/report/<%= report.id %>"><%= report.reportNumber || '' %></a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>