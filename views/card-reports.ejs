<%- include('partials/header') %>
<section class="panel table-panel">
  <div class="section-head">
    <div>
      <h2>Card Reports</h2>
      <p class="muted">Browse published card reports.</p>
    </div>
  </div>

  <div class="report-tools" style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:12px;">
    <input
      type="text"
      id="searchInput"
      placeholder="Search reports..."
      style="padding:8px 10px; min-width:260px; border:1px solid #d8c2b2; border-radius:8px;"
    />
  </div>

  <div class="table-wrap">
    <table id="reportsTable">
      <thead>
        <tr>
          <th>Image</th>
          <th>Card Name</th>
          <th>Card Grade</th>
          <th>Card #</th>
          <th>Card Set Name</th>
          <th>Report Date</th>
          <th>Report #</th>
          <th>Registered User</th>
        </tr>
      </thead>
      <tbody>
        <% reports.forEach(function(report) { %>
<tr>
  <!-- Image -->
<td>
  <a href="/report/<%= report.id %>">
    <img
      class="thumb"
      src="<%= report.cardImage || 'https://placehold.co/60x80?text=Card' %>"
      alt="<%= report.cardName || 'Card image' %>"
    />
  </a>
</td>

  <!-- Card Name -->
  <td><%= report.cardName || '' %></td>

  <!-- Card Grade -->
  <td><%= report.cardGrade || '' %></td>

  <!-- Card # -->
  <td><%= report.cardNumber || '' %></td>

  <!-- Card Set Name -->
  <td><%= report.setName || '' %></td>

  <!-- Report Date -->
  <td><%= report.reportDate ? new Date(report.reportDate).toLocaleDateString() : '' %></td>

  <!-- Report # -->
  <td><a href="/report/<%= report.id %>"><%= report.reportNumber %></a></td>

  <!-- Registered User -->
  <td><%= report.registeredUser || '' %></td>

</tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<script>
  (function () {
    const searchInput = document.getElementById('searchInput');
    const table = document.getElementById('reportsTable');
    if (!searchInput || !table) return;

    const rows = Array.from(table.querySelectorAll('tbody tr'));

    searchInput.addEventListener('input', function () {
      const term = this.value.toLowerCase().trim();

      rows.forEach((row) => {
        const text = row.innerText.toLowerCase();
        row.style.display = !term || text.includes(term) ? '' : 'none';
      });
    });
  })();
</script>
<%- include('partials/footer') %>
